{
    "name": "leaf-ng",
    "version": "1.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "deploy": "ng deploy --base-href=/leaf_ng/",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "format": "prettier --write \"src/**/*.{ts,html,css,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,html,css,json}\""
    },
    "prettier": {
        "overrides": [
            {
                "files": "*.html",
                "options": {
                    "parser": "angular"
                }
            }
        ]
    },
    "private": true,
    "dependencies": {
        "@angular/common": "^20.3.1",
        "@angular/compiler": "^20.3.1",
        "@angular/core": "^20.3.15",
        "@angular/forms": "^20.3.1",
        "@angular/platform-browser": "^20.3.1",
        "@angular/router": "^20.3.1",
        "@angular/service-worker": "^20.3.1",
        "@ngrx/store": "^20.0.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0",
        "zone.js": "~0.15.0"
    },
    "devDependencies": {
        "@angular-devkit/core": "^20.3.2",
        "@angular-devkit/schematics": "^20.3.2",
        "@angular/build": "^20.3.2",
        "@angular/cli": "^20.3.2",
        "@angular/compiler-cli": "^20.3.1",
        "@ngrx/schematics": "^20.0.0",
        "@nx/angular": "22.2.0",
        "@nx/workspace": "22.2.0",
        "@schematics/angular": "^20.3.2",
        "angular-cli-ghpages": "^2.0.3",
        "nx": "22.2.0",
        "prettier": "^3.8.1",
        "typescript": "~5.8.2",
        "typescript-eslint": "^8.57.1"
    }
}
